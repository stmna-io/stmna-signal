# STMNA Signal Pipeline — Environment Variables
# ================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# === Signal Messenger API ===
# URL of your signal-cli-rest-api or compatible service
SIGNAL_API_URL=http://your-signal-api:8082

# Your Signal phone number (registered account)
SIGNAL_PHONE_NUMBER=+1234567890

# UUID of the admin user (from your Signal account)
SIGNAL_ADMIN_UUID=your-admin-uuid-here

# === LLM Inference (llama-swap or compatible OpenAI-compatible endpoint) ===
LLAMA_SWAP_URL=http://your-llama-swap:8081

# Model to use for summarization (must be loaded in your inference server)
CHAT_MODEL=qwen3.5-35b-nothink

# Model to use for translation (larger model recommended)
TRANSLATION_MODEL=qwen3.5-122b

# === Whisper STT (for audio transcription) ===
# Dedicated whisper instance for Signal pipeline
WHISPER_URL=http://your-whisper-signal:8084

# === Web Scraping (crawl4ai) ===
CRAWL4AI_URL=http://your-crawl4ai:11235

# === Search Engine (SearXNG) ===
SEARXNG_URL=http://your-searxng:8080

# === PostgreSQL Database ===
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB_SIGNAL=stmna_signal

# === NextCloud (document and audio delivery) ===
NEXTCLOUD_URL=https://your-nextcloud/remote.php/webdav
NEXTCLOUD_USER=your-user
NEXTCLOUD_PASSWORD=your-password
NEXTCLOUD_AUDIO_PATH=/Shared/Pipeline/Audio
NEXTCLOUD_AUDIO_SIGNALS_PATH=/Shared/Pipeline/Audio/signals
NEXTCLOUD_AUDIO_BOOKS_PATH=/Shared/Pipeline/Audio/books

# === TTS (Kokoro text-to-speech) ===
KOKORO_TTS_URL=http://your-kokoro-tts:8880
KOKORO_DEFAULT_VOICE_EN=af_heart
KOKORO_DEFAULT_VOICE_FR=ff_siwis

# === Vault / Obsidian (vault write-back) ===
# URL of your n8n vault webhook
VAULT_WEBHOOK_URL=http://your-n8n:5678/webhook/vault

# === n8n Worker Settings ===
# 12 hours — needed for long-running book translation jobs (TEaR 3-pass)
N8N_RUNNERS_TASK_TIMEOUT=43200
N8N_RUNNERS_HEARTBEAT_INTERVAL=1800

# Required for Code nodes that use filesystem and child_process
NODE_FUNCTION_ALLOW_BUILTIN=fs,child_process,path
