# STMNA Signal — Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit your .env file to git.

# ── Inference (STMNA Desk) ────────────────────────────────────────────────────

# URL of your llama-swap instance (STMNA Desk or equivalent)
LLAMA_SWAP_URL=http://10.0.10.54:8081

# URL of your whisper.cpp Voice instance (Signal uses its own whisper container)
WHISPER_SIGNAL_URL=http://whisper-signal:8084

# Default summarization model (must be registered in llama-swap)
SUMMARIZATION_MODEL=qwen3.5-35b

# ── n8n ──────────────────────────────────────────────────────────────────────

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# Port for n8n web UI and API
N8N_PORT=5678

# Public webhook URL (used by signal-cli and external services)
N8N_WEBHOOK_URL=https://n8.yourdomain.com

# n8n task runner timeout in seconds (set high for long book translations)
N8N_RUNNERS_TASK_TIMEOUT=43200

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_USER=voice
POSTGRES_PASSWORD=
POSTGRES_DB=stmna_signal

# ── Signal Bot ────────────────────────────────────────────────────────────────

# signal-cli-rest-api endpoint (running on VPS or locally)
SIGNAL_CLI_URL=http://signal-cli:8080

# Phone number registered with Signal (with country code, e.g. +33612345678)
SIGNAL_PHONE_NUMBER=

# ── Obsidian Vault ────────────────────────────────────────────────────────────

# Host path to your Obsidian vault (mounted read-only into n8n)
VAULT_DIR=/data/second-brain

# ── Nextcloud (optional — for file ingestion pipeline) ────────────────────────

NEXTCLOUD_URL=https://n.yourdomain.com
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────

# Bearer token for webhook endpoints (generate: openssl rand -hex 32)
WEBHOOK_BEARER_TOKEN=

# ── SponsorBlock ─────────────────────────────────────────────────────────────

# SponsorBlock API base URL (public instance or self-hosted)
SPONSORBLOCK_API_URL=https://sponsor.ajay.app
